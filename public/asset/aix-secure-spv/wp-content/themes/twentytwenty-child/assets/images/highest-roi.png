    .we-reside .container::after {
        content: "";
        display:none;
    }
    .we-reside .container{
        position:relative;
    }
    .we-reside .container .plus::before {
        content: '';
        width: 15px;
        height: 15px;
        background-color: #c1785a!important;
        position: absolute;
        top: 138px !important;
        animation-name: pulse;
        animation-duration: 2s;
        animation-iteration-count: infinite;
        border-radius: 50%;
    }
    @keyframes pulse {
        0%   { left:0px; top:0px;}
        25%  { left:300px; top:0px;}
        50%  {left:300px; top:0px;}
        75%  {left:0px; top:0px;}
        100% { left:0px; top:0px;}
    }
    article.news.vertical.none {
        display: none;
    }
    @media (max-width: 1024px){
        @keyframes pulse {
            0%   { left:0px; top:0px;}
            25%  { left:180px; top:0px;}
            50%  {left:180px; top:0px;}
            75%  {left:0px; top:0px;}
            100% { left:0px; top:0px;}
        }
    }
    @media (min-width:1024px) and (max-width:1200px){
