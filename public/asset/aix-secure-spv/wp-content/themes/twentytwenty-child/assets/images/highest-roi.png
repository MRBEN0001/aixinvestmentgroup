    .marquee {
        height: 127px;
        will-change: transform;
        overflow: hidden;
        position: relative;
        transition: all .2s ease-out;
    }

    .marquee .large-row {
        display: flex;
        width: 280%;
        position: absolute;
        will-change: transform;
        animation: marquee 25s linear infinite;
        transition: all .2s ease-out;

    }
    .marquee:hover .large-row {
        animation-play-state: paused;
    }
    .c-card {
        transition: all .2s ease-out;
    }
    @keyframes marquee {
        0% { left: 0%; }
        100% { left: -140%; }
    }
