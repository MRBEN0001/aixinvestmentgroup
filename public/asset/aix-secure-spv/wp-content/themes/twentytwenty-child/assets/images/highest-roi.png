            50%  {left:215px; top:0px;}
            75%  {left:0px; top:0px;}
            100% { left:0px; top:0px;}
        }
    }
    @media (min-width:800px) and (max-width:1014px){
        @keyframes pulse {
            0%   { left:0px; top:0px;}
            25%  { left:170px; top:0px;}
            50%  {left:170px; top:0px;}
            75%  {left:0px; top:0px;}
            100% { left:0px; top:0px;}
        }
    }
    section.we-reside p span:before {
        content: "";
        display: block;
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        -webkit-transform: translateY(-50%);
        -moz-transform: translateY(-50%);
        -ms-transform: translateY(-50%);
        -o-transform: translateY(-50%);
        height: 1px;
        width: 100%;
        background: #b3774a;

    }
    section.we-reside p span:after {
        content: "";
        display: block;
        position: absolute;
        width: 18px;
        height: 18px;
